{
  "name": "ai-git-reviewer",
  "displayName": "AI Git Reviewer",
  "version": "0.1.0",
  "description": "Gemini/Claude 驱动的 GitHub/GitLab 代码审查 Chrome 扩展",
  "private": true,
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "@google/generative-ai": "^0.24.0",
    "@octokit/rest": "^21.1.1",
    "@plasmohq/messaging": "^0.6.2",
    "@plasmohq/storage": "^1.13.0",
    "@types/dompurify": "^3.0.5",
    "clsx": "^2.1.1",
    "dompurify": "^3.3.3",
    "lucide-react": "^0.475.0",
    "marked": "^17.0.4",
    "plasmo": "0.90.5",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-syntax-highlighter": "^16.1.1",
    "tiktoken": "^1.0.21"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.321",
    "@types/node": "^22.14.0",
    "@types/react": "18.2.0",
    "@types/react-dom": "18.2.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2"
  },
  "manifest": {
    "host_permissions": [
      "https://api.github.com/*",
      "https://*/*"
    ],
    "permissions": [
      "storage",
      "sidePanel",
      "tabs",
      "activeTab"
    ]
  }
}
